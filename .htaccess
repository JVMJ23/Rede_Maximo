# ===============================================
# REDE MÁXIMO SUPERMERCADOS - .htaccess
# Versão: 2025 - Produção
# ===============================================

# ===== FORÇA HTTPS =====
RewriteEngine On
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# ===== REDIRECIONAMENTOS =====
# www para não-www (ou vice-versa - escolha uma opção)
RewriteCond %{HTTP_HOST} ^www\.(.*)$ [NC]
RewriteRule ^(.*)$ https://%1/$1 [R=301,L]

# URLs amigáveis para produtos
RewriteRule ^produtos/chocomax/?$ pages/produtosmax/chocomax.html [L]
RewriteRule ^produtos/vinhocedro/?$ pages/produtosmax/vinhocedro.html [L]
RewriteRule ^produtos/cafemax/?$ pages/produtosmax/cafemax.html [L]
RewriteRule ^produtos/carvaomax/?$ pages/produtosmax/carvaomax.html [L]
RewriteRule ^produtos/aguamax/?$ pages/produtosmax/aguamax.html [L]
RewriteRule ^produtos/ovospascoa/?$ pages/produtosmax/ovospascoa.html [L]

# URLs amigáveis para receitas
RewriteRule ^receitas/panacota/?$ pages/receitasmax/rec1-panacota.html [L]
RewriteRule ^receitas/bacalhau/?$ pages/receitasmax/rec2-bacalhau.html [L]
RewriteRule ^receitas/mousse/?$ pages/receitasmax/rec3-mousse.html [L]
RewriteRule ^receitas/abobora/?$ pages/receitasmax/rec4-abobora.html [L]

# ===== HEADERS DE SEGURANÇA MÁXIMA =====
<IfModule mod_headers.c>
    # Content Security Policy - Específico para Rede Máximo
    Header always set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://www.google.com https://www.gstatic.com https://cdnjs.cloudflare.com https://www.googletagmanager.com https://www.google-analytics.com https://ssl.google-analytics.com https://www.googleadservices.com https://googleads.g.doubleclick.net https://formsubmit.co; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; img-src 'self' data: https: blob:; font-src 'self' https://fonts.gstatic.com https://cdnjs.cloudflare.com; connect-src 'self' https://www.google-analytics.com https://analytics.google.com https://formsubmit.co https://api.whatsapp.com; frame-src https://www.google.com https://docs.google.com; object-src 'none'; base-uri 'self'; form-action 'self' https://formsubmit.co https://wa.me;"
    
    # Proteções fundamentais
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-XSS-Protection "1; mode=block"
    
    # Segurança moderna
    Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set Permissions-Policy "camera=(), microphone=(), geolocation=(), payment=(), usb=(), magnetometer=(), gyroscope=(), speaker=()"
    
    # Performance headers
    Header always set Vary "Accept-Encoding"
    Header always set X-Robots-Tag "index, follow"
</IfModule>

# ===== CACHE OTIMIZADO PARA SUPERMERCADO =====
<IfModule mod_expires.c>
    ExpiresActive On
    
    # Imagens de produtos - cache longo (raramente mudam)
    ExpiresByType image/jpg "access plus 1 year"
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/webp "access plus 1 year"
    ExpiresByType image/gif "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 year"
    ExpiresByType image/x-icon "access plus 1 year"
    
    # CSS e JS - cache médio
    ExpiresByType text/css "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
    ExpiresByType application/x-javascript "access plus 1 month"
    ExpiresByType text/javascript "access plus 1 month"
    
    # Fontes - cache longo
    ExpiresByType font/woff "access plus 1 year"
    ExpiresByType font/woff2 "access plus 1 year"
    ExpiresByType application/font-woff "access plus 1 year"
    ExpiresByType application/font-woff2 "access plus 1 year"
    ExpiresByType font/truetype "access plus 1 year"
    ExpiresByType font/opentype "access plus 1 year"
    
    # HTML - cache curto (ofertas mudam frequentemente)
    ExpiresByType text/html "access plus 1 hour"
    
    # Documentos
    ExpiresByType application/pdf "access plus 1 week"
    ExpiresByType application/xml "access plus 1 hour"
    ExpiresByType text/xml "access plus 1 hour"
</IfModule>

# Cache especial para páginas que mudam mais
<LocationMatch "/(ofertas|novidades)">
    ExpiresActive On
    ExpiresByType text/html "access plus 10 minutes"
    ExpiresByType image/png "access plus 1 day"
    ExpiresByType image/jpg "access plus 1 day"
</LocationMatch>

# ===== COMPRESSÃO GZIP =====
<IfModule mod_deflate.c>
    # Tipos de arquivo para comprimir
    AddOutputFilterByType DEFLATE text/html
    AddOutputFilterByType DEFLATE text/css
    AddOutputFilterByType DEFLATE text/javascript
    AddOutputFilterByType DEFLATE text/xml
    AddOutputFilterByType DEFLATE text/plain
    AddOutputFilterByType DEFLATE application/javascript
    AddOutputFilterByType DEFLATE application/x-javascript
    AddOutputFilterByType DEFLATE application/xml
    AddOutputFilterByType DEFLATE application/xhtml+xml
    AddOutputFilterByType DEFLATE application/rss+xml
    AddOutputFilterByType DEFLATE application/atom_xml
    AddOutputFilterByType DEFLATE image/svg+xml
    AddOutputFilterByType DEFLATE application/json
    AddOutputFilterByType DEFLATE application/ld+json
    
    # Exceções
    SetEnvIfNoCase Request_URI \.(?:gif|jpe?g|png|webp)$ no-gzip dont-vary
    SetEnvIfNoCase Request_URI \.(?:exe|t?gz|zip|bz2|sit|rar)$ no-gzip dont-vary
</IfModule>

# ===== PROTEÇÃO DE ARQUIVOS SENSÍVEIS =====
<Files ".htaccess">
    Order Allow,Deny
    Deny from all
</Files>

<Files "*.log">
    Order Allow,Deny
    Deny from all
</Files>

<Files "*.env">
    Order Allow,Deny
    Deny from all
</Files>

<Files "config.php">
    Order Allow,Deny
    Deny from all
</Files>

<Files "*.bak">
    Order Allow,Deny
    Deny from all
</Files>

# ===== BLOQUEIO DE BOTS E ATAQUES =====
<IfModule mod_rewrite.c>
    # Bloquear bots maliciosos
    RewriteCond %{HTTP_USER_AGENT} (ahrefs|semrush|mj12bot|dotbot|seokicks) [NC]
    RewriteRule .* - [F,L]
    
    # Bloquear tentativas de hack comuns
    RewriteCond %{QUERY_STRING} (eval\(|union.*select|concat.*\(|base64_decode) [NC]
    RewriteRule .* - [F,L]
    
    # Bloquear acesso direto a arquivos PHP (se houver)
    RewriteCond %{THE_REQUEST} /([^/\s?]*\.php)[?\s] [NC]
    RewriteRule ^(.*)$ - [F,L]
</IfModule>

# ===== PREVENÇÃO DE HOTLINKING =====
<IfModule mod_rewrite.c>
    RewriteCond %{HTTP_REFERER} !^$
    RewriteCond %{HTTP_REFERER} !^https?://(www\.)?supermercadomaximo\.com\.br [NC]
    RewriteCond %{HTTP_REFERER} !^https?://(www\.)?google\. [NC]
    RewriteCond %{HTTP_REFERER} !^https?://(www\.)?bing\. [NC]
    RewriteCond %{HTTP_REFERER} !^https?://(www\.)?facebook\. [NC]
    RewriteCond %{HTTP_REFERER} !^https?://(www\.)?instagram\. [NC]
    RewriteRule \.(jpe?g|png|gif|webp|css|js)$ - [F,L]
</IfModule>

# ===== OTIMIZAÇÕES DE PERFORMANCE =====
# Remove ETags desnecessários
<IfModule mod_headers.c>
    Header unset ETag
</IfModule>
FileETag None

# Desabilita server signature
ServerSignature Off

# ===== PÁGINAS DE ERRO PERSONALIZADAS =====
ErrorDocument 404 /404.html
ErrorDocument 403 /403.html
ErrorDocument 500 /500.html

# ===== TIPOS MIME MODERNOS =====
<IfModule mod_mime.c>
    # WebP
    AddType image/webp .webp
    
    # Fontes modernas
    AddType font/woff .woff
    AddType font/woff2 .woff2
    AddType application/font-woff .woff
    AddType application/font-woff2 .woff2
    
    # JSON
    AddType application/json .json
    AddType application/ld+json .jsonld
    
    # Outros
    AddType text/cache-manifest .appcache .manifest
</IfModule>

# ===== CONFIGURAÇÕES ESPECÍFICAS PARA E-COMMERCE =====
# Headers para melhorar conversão
<IfModule mod_headers.c>
    # Preload de recursos críticos
    Header add Link "</assets/css/global/global.css>; rel=preload; as=style"
    Header add Link "</assets/images/global/logo-novo-02.png>; rel=preload; as=image"
    
    # Prefetch para páginas importantes
    Header add Link "</ofertas.html>; rel=prefetch"
    Header add Link "</compre.html>; rel=prefetch"
</IfModule>

# ===== PROTEÇÃO CONTRA ATAQUES DDOS BÁSICOS =====
<IfModule mod_limitipconn.c>
    MaxConnPerIP 20
</IfModule>

# ===== CONFIGURAÇÕES PARA PWA (FUTURO) =====
<IfModule mod_mime.c>
    AddType application/manifest+json .webmanifest
    AddType text/cache-manifest .manifest
</IfModule>

# ===== LOGS DE SEGURANÇA =====
<IfModule mod_log_config.c>
    LogFormat "%h %l %u %t \"%r\" %>s %b \"%{Referer}i\" \"%{User-agent}i\"" combined
    CustomLog logs/access.log combined
</IfModule>

# ===== FALLBACK PARA NAVEGADORES ANTIGOS =====
<IfModule mod_headers.c>
    # Adiciona headers de compatibilidade
    Header always set X-UA-Compatible "IE=edge"
</IfModule>
